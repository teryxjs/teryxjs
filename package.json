{
  "name": "teryx",
  "version": "0.1.0",
  "description": "Enterprise widget framework built on xhtmlx — Sencha-grade components for JSON-driven UIs",
  "type": "module",
  "main": "./dist/teryx.cjs",
  "module": "./dist/teryx.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/teryx.js",
      "require": "./dist/teryx.cjs",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/teryx.css"
  },
  "files": [
    "dist",
    "xhtmlx.js"
  ],
  "scripts": {
    "build": "tsup && cp styles/teryx.css dist/teryx.css",
    "dev": "tsup --watch",
    "demo": "node examples/server.cjs",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.ts' '*.json'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' '*.ts' '*.json'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test --config tests/browser/playwright.config.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "xhtmlx",
    "widgets",
    "ui",
    "framework",
    "components",
    "enterprise"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "express": "^4.18.2",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^1.3.0"
  }
}
